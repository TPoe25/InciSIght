generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  createdAt DateTime @default(now())

  profile      UserProfile?
  scans        Scan[]
  subscription Subscription?
}

model UserProfile {
  id        String @id @default(uuid())
  userId    String @unique
  skinType  String?
  preferences String[]
  allergies  String[]

  user User @relation(fields: [userId], references: [id])
}

model Product {
  id         String   @id @default(uuid())
  name       String
  brand      String?
  category   String?
  barcode    String? @unique

  baseScore  Int?
  scoreColor String?

  ingredients ProductIngredient[]
  scans       Scan[]
}

model Ingredient {
  id        String @id @default(uuid())
  name      String @unique
  riskLevel String
  description String?

  products ProductIngredient[]
}

model ProductIngredient {
  productId    String
  ingredientId String

  product    Product    @relation(fields: [productId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@id([productId, ingredientId])
}

model Scan {
  id        String   @id @default(uuid())
  userId    String?
  productId String?

  score     Int?
  color     String?

  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
}

model Subscription {
  id     String @id @default(uuid())
  userId String @unique
  plan   String

  user User @relation(fields: [userId], references: [id])
}
